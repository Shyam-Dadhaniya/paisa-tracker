# Copy this file to .env.local and fill in.
# .env.local is gitignored — secrets stay local until you set them in Vercel.

# Supabase — publishable key is safe to ship to client (RLS protects data)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx

# Groq (free tier) — server-side only (used by /api/parse-sms)
# Get free key at https://console.groq.com — no credit card needed
GROQ_API_KEY=gsk_...
